# Copy this file to .env and fill in your values

# Claude API Key — get from console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here

# Neon PostgreSQL connection string — get from neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Frontend URL for CORS — set to your Render frontend URL in production
FRONTEND_URL=https://your-budgetai-frontend.onrender.com

# Port (optional, defaults to 3001)
PORT=3001
